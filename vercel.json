{
  "buildCommand": "pip install -r requirements.txt",
  "devCommand": "streamlit run app_v2.py --server.port 3000 --server.headless true",
  "installCommand": "pip install -r requirements.txt",
  "outputDirectory": ".streamlit",
  "framework": "streamlit",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.10"
  }
}
