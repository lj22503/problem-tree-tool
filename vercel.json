{
  "version": 2,
  "builds": [
    {
      "src": "vercel_app/api/index.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 60 }
    },
    {
      "src": "vercel_app/index.html",
      "use": "@vercel/static",
      "config": { "contentType": "text/html" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "vercel_app/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "vercel_app/index.html"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.10"
  }
}
